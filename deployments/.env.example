# Copy to .env and adjust as needed. Unset variables fall back to the documented
# BuddyNet defaults, so an empty .env is fine.
#
#   cp deployments/.env.example deployments/.env

# UDP port for the handshake (matchmaking) server. Default: 51820
BUDDYNET_HANDSHAKE_PORT=51820

# UDP port for the blind relay. Default: 51821
BUDDYNET_RELAY_PORT=51821
