# BuddyNet Lab — environment template
#
# DO NOT fill this in manually.
# Run setup.sh — it bootstraps the server identity and writes .env automatically.
#
#   cd lab && ./setup.sh

# Ed25519 public key of the handshake server (base64).
# Buddies pin this key to authenticate the server's signed PEER_LIST responses.
# Written by setup.sh after the server generates its identity key on first start.
BUDDYNET_SERVER_KEY=
