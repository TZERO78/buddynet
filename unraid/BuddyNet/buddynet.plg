<!-- service control script -->
<FILE Name="/etc/rc.d/rc.buddynet" Mode="0755">
<INLINE>
<![CDATA[
#!/bin/bash
# rc.buddynet — control the BuddyNet tunnel (buddy role)
CFG=/boot/config/plugins/buddynet/buddynet.cfg
BIN=/usr/local/bin/buddynet
# Identity key, trust store and peer cache live on the array (real 0600 perms),
# not the FAT flash. Requires the array to be started — the service runs on the
# array event.
STATE=/mnt/user/appdata/buddynet
PIDFILE=/var/run/buddynet.pid
LOG=/var/log/buddynet.log
[ -f "$CFG" ] && . "$CFG"

# Trim stray leading/trailing whitespace from values (a space pasted into a
# field would otherwise break e.g. DNS resolution of the server address).
trim() { local s="$*"; s="${s#"${s%%[![:space:]]*}"}"; s="${s%"${s##*[![:space:]]}"}"; printf '%s' "$s"; }
SERVER="$(trim "${SERVER:-}")"; SERVER_KEY="$(trim "${SERVER_KEY:-}")"; TOKEN="$(trim "${TOKEN:-}")"
TOKEN_FILE="$(trim "${TOKEN_FILE:-}")"; PEER_KEY="$(trim "${PEER_KEY:-}")"
LISTEN="$(trim "${LISTEN:-}")"; FORWARD="$(trim "${FORWARD:-}")"
NAME="$(trim "${NAME:-}")"; DNS="$(trim "${DNS:-}")"; LAZY="$(trim "${LAZY:-}")"

is_running() { [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; }

start() {
  [ "$SERVICE" = "enable" ] || { echo "disabled"; return 0; }
  is_running && { echo "running"; return 0; }
  [ -x "$BIN" ] || { echo "binary missing"; return 1; }
  mkdir -p "$STATE" 2>/dev/null || { echo "appdata unavailable (is the array started?)"; return 1; }
  # Headless: there is no terminal to compare a first-contact SAS, so run
  # --no-interactive (an unknown buddy key is refused, never learned blind) and
  # pin the buddy with --peer-key. Without a pin the buddy will refuse to connect.
  args=(--role=buddy --server "$SERVER" --server-key "$SERVER_KEY"
        --key "$STATE/id.key" --known-peers "$STATE/known_peers"
        --peers "$STATE/peers.json" --no-interactive)
  if [ -n "$PEER_KEY" ]; then
    args+=(--peer-key "$PEER_KEY")
  else
    echo "WARNING: no Buddy key set — headless has no SAS prompt, so the connection will be refused. Set the Buddy key (your buddy's identity) to pin it." >>"$LOG"
  fi
  [ -n "$LISTEN" ]  && args+=(-L "$LISTEN")
  [ -n "$FORWARD" ] && args+=(-forward "$FORWARD")
  # BuddyDNS: self-asserted .buddy name and/or the stub resolver (root here, so
  # the privileged 127.0.0.153:53 bind succeeds).
  [ -n "$NAME" ] && args+=(--name "$NAME")
  [ "$DNS" = "enable" ] && args+=(--dns)
  # Lazy needs -L (there is no listener to hold open without it); skip + warn.
  if [ "$LAZY" = "enable" ]; then
    if [ -n "$LISTEN" ]; then
      args+=(--lazy)
    else
      echo "WARNING: Lazy tunnel is enabled but no -L (Expose local port) is set — ignoring --lazy." >>"$LOG"
    fi
  fi
  # WireGuard data plane: the peer tunnel runs over kernel WireGuard (the partner
  # is reachable natively at its VIP). Control plane stays QUIC/plain.
  [ "$WIREGUARD" = "enable" ] && args+=(--wireguard)
  # Prefer the token from a file on the array (real 0600 perms) over the flash
  # cfg value; /boot is FAT and cannot enforce permissions. Only override when the
  # file is non-empty and readable (an empty file must not blank out the token).
  tok="$TOKEN"
  if [ -n "$TOKEN_FILE" ] && [ -s "$TOKEN_FILE" ] && [ -r "$TOKEN_FILE" ]; then
    ftok="$(trim "$(tr -d '\r\n' < "$TOKEN_FILE")")"
    [ -n "$ftok" ] && tok="$ftok"
  fi
  # token via env so it does not appear in ps
  BUDDYNET_TOKEN="$tok" nohup "$BIN" "${args[@]}" >>"$LOG" 2>&1 &
  echo $! > "$PIDFILE"
  echo "started"
}
stop() { is_running && kill "$(cat "$PIDFILE")" 2>/dev/null; rm -f "$PIDFILE"; echo "stopped"; }
# really delete a file: shred if available (best effort on SSD/CoW), else rm
wipe() { [ -f "$1" ] && { shred -u "$1" 2>/dev/null || rm -f "$1"; }; }
forget_buddy()   { wipe "$STATE/known_peers"; echo "trust store cleared"; stop; sleep 1; start; }
reset_identity() { stop; wipe "$STATE/id.key"; wipe "$STATE/known_peers"; echo "identity + trust store deleted"; sleep 1; start; }
# rate: connection counts + throughput (bytes/sec) per direction, measured on the
# loopback forwarded sockets (-L listener = "out" path, -forward target = "in").
rate() {
  local lp="${LISTEN##*:}" fp="${FORWARD##*:}"
  # ports come from the (user-written) cfg — keep only digits before they reach ss
  lp="${lp//[^0-9]/}"; fp="${fp//[^0-9]/}"
  bytes() { ss -tinH state established "$1" 2>/dev/null | grep -oE 'bytes_(sent|received):[0-9]+' | awk -F: '{s+=$2}END{print s+0}'; }
  count() { ss -tnH  state established "$1" 2>/dev/null | grep -c . ; }
  local oc=0 ic=0 o1=0 i1=0 o2=0 i2=0
  [ -n "$lp" ] && { oc=$(count "sport = :$lp"); o1=$(bytes "sport = :$lp"); }
  [ -n "$fp" ] && { ic=$(count "dport = :$fp"); i1=$(bytes "dport = :$fp"); }
  sleep 1
  [ -n "$lp" ] && o2=$(bytes "sport = :$lp")
  [ -n "$fp" ] && i2=$(bytes "dport = :$fp")
  echo "oc=$oc ic=$ic out=$((o2-o1)) in=$((i2-i1))"
}
case "$1" in
  start)         start ;;
  stop)          stop ;;
  restart)       stop; sleep 1; start ;;
  status)        is_running && echo running || echo stopped ;;
  rate)          rate ;;
  forget-buddy)  forget_buddy ;;
  reset-identity) reset_identity ;;
  *)             echo "usage: $0 {start|stop|restart|status|rate|forget-buddy|reset-identity}" ;;
esac
]]>
</INLINE>
</FILE>

<!-- start on array-up (so a token file on /mnt/user is available), stop on array-down -->
<FILE Name="&emhttp;/event/started" Mode="0755">
<INLINE>
<![CDATA[
#!/bin/bash
/etc/rc.d/rc.buddynet restart >/dev/null 2>&1 &
]]>
</INLINE>
</FILE>

<FILE Name="&emhttp;/event/stopping" Mode="0755">
<INLINE>
<![CDATA[
#!/bin/bash
/etc/rc.d/rc.buddynet stop >/dev/null 2>&1
]]>
</INLINE>
</FILE>

<!-- install: fetch binary (once, persisted on flash), seed config, start -->
<FILE Run="/bin/bash" Method="install">
<INLINE>
<![CDATA[
set -e
PLG=/boot/config/plugins/buddynet
mkdir -p "$PLG"

# NOTE: entities are NOT expanded inside <FILE> CDATA on Unraid, so the binary
# version and URL are hard-coded here on purpose.
# MAINTAINER: bump both together on each new release (tag -> release.yml build).
BINVER="v2.3.0"
BINURL="https://github.com/TZERO78/buddynet/releases/download/${BINVER}/buddynet-linux-amd64"
# SHA256 of the release binary; verified on every install so a corrupted or
# tampered download is never installed. Matches buddynet-linux-amd64.sha256 of
# the BINVER release — bump both together on each new release.
BINSHA="f20f7e5ec9fb01ff5dd363c95998e4c02a3a0b8d546e94924a28bbab3fa58530"
verify() { echo "$BINSHA  $1" | sha256sum -c --status 2>/dev/null; }

# Download the buddynet binary to flash (only if missing or its checksum is wrong).
if [ ! -s "$PLG/buddynet" ] || ! verify "$PLG/buddynet"; then
  echo "Downloading buddynet ${BINVER} ..."
  wget -qO "$PLG/buddynet" "$BINURL" || { echo "download failed"; rm -f "$PLG/buddynet"; exit 1; }
fi
if ! verify "$PLG/buddynet"; then
  echo "checksum mismatch — refusing to install (expected $BINSHA)"
  rm -f "$PLG/buddynet"; exit 1
fi
install -m0755 "$PLG/buddynet" /usr/local/bin/buddynet
chmod 0755 /etc/rc.d/rc.buddynet

# Install the plugin logo (used by the Tools tile and the Plugins page).
EMHTTP=/usr/local/emhttp/plugins/buddynet
mkdir -p "$EMHTTP"
base64 -d > "$EMHTTP/buddynet.png" <<'PNG'
