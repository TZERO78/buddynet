<?php
$cfg = parse_plugin_cfg("buddynet");
function v($cfg,$k,$d=''){ return htmlspecialchars(isset($cfg[$k])?$cfg[$k]:$d); }
$running = trim(shell_exec("/etc/rc.d/rc.buddynet status 2>/dev/null"));
$last = trim(shell_exec("grep -aE 'ONLINE|OFFLINE|REACHABLE|DISCONNECTED|waiting for buddy|tunnel error|^error' /var/log/buddynet.log 2>/dev/null | tail -n 1"));
$ident = trim(shell_exec("grep -aoE 'identity [A-Za-z0-9+/=]{40,}' /var/log/buddynet.log 2>/dev/null | tail -n 1 | cut -d' ' -f2"));
// online state from the last meaningful log line
if    (strpos($last,'✓ ONLINE')!==false || strpos($last,'REACHABLE')!==false) $online='🟢 online';
elseif(strpos($last,'waiting')!==false)                                        $online='🟡 waiting for buddy';
elseif(strpos($last,'OFFLINE')!==false || strpos($last,'DISCONNECTED')!==false)$online='🔴 buddy offline';
else                                                                            $online=$last?:'unknown';
?>
<div style="margin-bottom:1em;color:#777">
The encrypted "cable" between two buddies — finds your partner via the handshake
server, punches through NAT (no port forwarding), runs a direct QUIC tunnel, and
falls back to a blind relay only if needed. Point rsync/borg/kopia at the local
socket.
</div>

