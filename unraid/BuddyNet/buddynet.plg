# Seed a default config on first install only (never overwrite the user's).
if [ ! -f "$PLG/buddynet.cfg" ]; then
  cat > "$PLG/buddynet.cfg" <<'CFG'
SERVICE="disable"
SERVER=""
SERVER_KEY=""
TOKEN=""
# Default to a token file on the array (real 0600) rather than the FAT flash.
# Create it (see the Secret note on the page); the plain TOKEN field is a
# testing fallback used only when this file is absent.
TOKEN_FILE="/mnt/user/appdata/buddynet/token"
PEER_KEY=""
LISTEN="127.0.0.1:9000"
FORWARD="127.0.0.1:873"
CFG
fi
chmod 0600 "$PLG/buddynet.cfg"

/etc/rc.d/rc.buddynet restart >/dev/null 2>&1 || true
echo ""
echo "BuddyNet installed. Configure it under Tools -> BuddyNet."
]]>
</INLINE>
</FILE>

<!-- remove: stop and clean up -->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
/etc/rc.d/rc.buddynet stop >/dev/null 2>&1 || true
rm -f /usr/local/bin/buddynet /etc/rc.d/rc.buddynet
rm -rf /usr/local/emhttp/plugins/buddynet
# Clean uninstall: remove the config + binary from flash...
rm -rf /boot/config/plugins/buddynet
# ...and the identity key + trust store + peer cache from the array (leave a
# user-placed token file and the appdata dir itself alone). Array may be down here.
rm -f /mnt/user/appdata/buddynet/id.key /mnt/user/appdata/buddynet/known_peers /mnt/user/appdata/buddynet/peers.json 2>/dev/null || true
echo "BuddyNet removed. Config (flash) and identity/trust/cache (appdata) deleted."
]]>
</INLINE>
</FILE>

</PLUGIN>
